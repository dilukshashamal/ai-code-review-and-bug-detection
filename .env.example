# Shared local development defaults
APP_ENV=development

# Frontend
VITE_GRAPHQL_ENDPOINT=http://localhost:8000/graphql

# Backend
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/code_review_db
OPENAI_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY is also supported by the Google Gen AI SDK.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
ENABLE_GEMINI_REVIEW=true
JWT_SECRET=change-me-in-local-env
GRAPHQL_DEBUG=true
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
